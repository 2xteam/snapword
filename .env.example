# 로컬: 복사 후 `.env.local`로 저장하고 <db_password> 등을 채우세요.

# DB 이름은 경로의 /vocab (컬렉션 이름 아님). 컬렉션: users, folders, vocabularies, words, study_records, test_sessions, test_results, openai_request_logs, chat_threads, chat_messages

# querySrv ECONNREFUSED 오류 시: mongodb+srv 대신 Atlas에서 복사한 mongodb:// 표준 연결 문자열을 MONGO_URI에 넣으세요 (SRV DNS 미사용).

MONGO_URI=mongodb+srv://2xteam:<db_password>@cluster0.byos9f6.mongodb.net/vocab?retryWrites=true&w=majority&appName=Cluster0

# https://platform.openai.com/api-keys — `sk-` 또는 `sk-proj-` 로 시작하는 비밀 키
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# (선택) 모든 OpenAI 단어 JSON 호출에 합쳐지는 전역 지침. 여러 줄 가능, 약 4000자까지.
# OPENAI_EXTRA_INSTRUCTIONS=meaning은 항상 한국어로 작성하세요.
# 이미지 전용 Vision 모델(미설정 시 OPENAI_MODEL 또는 gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini
# Vision 해상도: high(기본) | low — 토큰·비용 절감 시 low
# OPENAI_IMAGE_DETAIL=low
